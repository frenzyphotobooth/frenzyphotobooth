<nav class="navbar" id="navbar">
  <div class="container nav-container">
    <a href="/" class="logo">
      <img src="{{ site.brand.logoSrc }}" alt="{{ site.brand.logoAlt }}" class="logo-img">
      <span class="logo-text">{{ site.brand.name }} <span class="logo-accent">{{ site.brand.accent }}</span></span>
    </a>
    <ul class="nav-links" id="navLinks">
      {% for item in site.navigation.links %}
      <li><a href="{{ item.href }}">{{ item.label }}</a></li>
      {% endfor %}
      <li><a href="{{ site.navigation.cta.href }}" class="btn btn-nav">{{ site.navigation.cta.label }}</a></li>
      <li>
        <button class="theme-toggle" id="themeToggle" aria-label="{{ site.navigation.themeToggleAriaLabel }}">
          <span class="theme-icon sun">☀️</span>
          <span class="theme-icon moon">🌙</span>
        </button>
      </li>
    </ul>
    <div class="nav-right-mobile">
      <button class="theme-toggle theme-toggle-mobile" id="themeToggleMobile" aria-label="{{ site.navigation.themeToggleAriaLabel }}">
        <span class="theme-icon sun">☀️</span>
        <span class="theme-icon moon">🌙</span>
      </button>
      <button class="nav-toggle" id="navToggle" aria-label="{{ site.navigation.mobileMenuAriaLabel }}">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>
