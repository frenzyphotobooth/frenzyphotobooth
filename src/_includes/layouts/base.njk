<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  {% include "partials/nav.njk" %}
  {{ content | safe }}
  {% if not hideFloatingQuote %}
  <a href="{{ site.navigation.cta.href }}" class="btn btn-primary floating-quote-btn" aria-label="{{ site.navigation.cta.label }}">
    {{ site.navigation.cta.label }}
  </a>
  {% endif %}
  {% include "partials/footer.njk" %}
  <script src="/js/features/ui/floating-quote.js"></script>
  {% for script in scripts %}
  <script src="{{ script }}"></script>
  {% endfor %}
</body>
</html>
