        <p class="section-desc">Browse photo categories and tap in to view full event albums.</p>
      </div>
      <div class="gallery-tabs" id="galleryTabs" role="tablist" aria-label="Gallery media type">
        <button class="gallery-tab is-active" data-gallery-tab="photo" role="tab" aria-selected="true">Photos</button>
        <button class="gallery-tab" data-gallery-tab="video" role="tab" aria-selected="false">Videos</button>
      </div>
      <div class="gallery-grid" id="galleryGrid"></div>
    </div>
  </section>
  <script>
    window.FRENZY_DRIVE_API_KEY = "{{ env.driveApiKey }}";
  </script>

  <!-- Theme Preview -->
  <section class="section theme-preview" id="theme-preview">
    <div class="container">
      <div class="section-header">
        <p class="section-tag">Branding</p>
