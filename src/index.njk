            <li>Slow-motion video effects</li>
            <li>Instant sharing via text or email</li>
            <li>Online gallery with all event captures</li>
            <li>3 HRS STANDARD RENTAL TIME</li>
            <li>Extra Hour - $150/hr</li>
          </ul>
          <a href="{{ '/get-quote' | withBase(site.basePath) }}" class="btn btn-primary btn-block">Get a Quote</a>
        </div>
        <div class="service-card" data-aos="fade-up" data-aos-delay="200">
          <div class="card-badge">Premium</div>
          <h3>Frenzy Studio Booth</h3>
          <p class="card-subtitle">The Prestige</p>
          <p class="card-price"><span>$1200</span></p>
          <ul class="card-features">
            <li>Standard backdrop</li>
            <li>Props and prop table</li>
            <li>Prints &amp; Digital Photos</li>
            <li>Premium lighting</li>
            <li>Instant sharing via text or email</li>
            <li>Online gallery with all event captures</li>
            <li>3 HRS STANDARD RENTAL TIME</li>
            <li>Extra Hour - $175/hr</li>
          </ul>
          <a href="{{ '/get-quote' | withBase(site.basePath) }}" class="btn btn-primary btn-block">Get a Quote</a>
        </div>
      </div>

