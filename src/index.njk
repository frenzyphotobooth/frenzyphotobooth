          <div class="addon-card">
            <div class="addon-icon">✨</div>
            <div>
              <h3>Premium Backdrop</h3>
              <p>Upgrade to sequin, floral, shimmer or custom backdrop.</p>
              <strong>$150 - $250</strong>
            </div>
          </div>

          <div class="addon-card">
            <div class="addon-icon">🖥️</div>
