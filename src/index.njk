              <strong>$100</strong>
            </div>
          </div>

          <div class="addon-card">
            <div class="addon-icon">📸</div>
            <div>
              <h3>Prints</h3>
              <p>High-quality prints for your guests.</p>
              <strong>$200</strong>
            </div>
          </div>


          <div class="addon-card">
            <div class="addon-icon">🥸</div>
            <div>
              <h3>Premium Props Package</h3>
              <p>Themed props to match your event.</p>
              <strong>$75</strong>
            </div>
          </div>


          <div class="addon-card">
            <div class="addon-icon">🚚</div>
            <div>
              <h3>Travel Fee</h3>
              <p>Applies outside our local service area.</p>
